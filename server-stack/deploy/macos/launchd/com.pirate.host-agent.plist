<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.pirate.host-agent</string>
  <key>UserName</key>
  <string>pirate</string>
  <key>GroupName</key>
  <string>staff</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/libexec/pirate/run-host-agent.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/var/lib/pirate</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/var/log/pirate/host-agent.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/pirate/host-agent.err</string>
</dict>
</plist>

# Скопируйте в /etc/pirate-deploy.env и поправьте при необходимости.
# Файл обычно root:pirate, chmod 640 — читает группа pirate (сервисы и пользователь pirate).
#
# Нативная установка (install.sh): метаданные в SQLite.
DEPLOY_SQLITE_URL=sqlite:///var/lib/pirate/deploy/deploy.db
#
# Docker / отдельный Postgres для метаданных (не смешивайте с DEPLOY_SQLITE_URL на одном хосте без необходимости):
# DATABASE_URL=postgresql://deploy:CHANGEME@127.0.0.1:5432/deploy
#
# Опционально: отдельный PostgreSQL только для встроенного explorer в UI (когда метаданные в SQLite).
# install.sh с pirate_INSTALL_POSTGRESQL=1 добавит строку автоматически; либо вручную:
# POSTGRES_EXPLORER_URL=postgresql://user:pass@127.0.0.1:5432/otherdb
#
# SMB mount helpers (по умолчанию после install.sh):
# CONTROL_API_SMB_MOUNT_SCRIPT=/usr/local/lib/pirate/pirate-smb-mount.sh
# CONTROL_API_SMB_UMOUNT_SCRIPT=/usr/local/lib/pirate/pirate-smb-umount.sh

DEPLOY_ROOT=/var/lib/pirate/deploy
GRPC_ENDPOINT=http://[::1]:50051
CONTROL_API_PORT=8080
# install.sh задаёт 127.0.0.1 (только localhost); для Docker/всех интерфейсов не задавайте или укажите ::
CONTROL_API_BIND=127.0.0.1
RUST_LOG=info

# С --ui install.sh добавляет CONTROL_UI_ADMIN_* и CONTROL_API_JWT_SECRET (дашборд + JWT для /api/v1/*).
# Без --ui эти переменные не пишутся — HTTP API без Bearer (см. README).

CONTROL_API_HOST_STATS_SERIES=1

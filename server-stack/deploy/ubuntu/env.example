# Скопируйте в /etc/pirate-deploy.env и поправьте при необходимости.
# Файл обычно root:pirate, chmod 640 — читает группа pirate (сервисы и пользователь pirate).
# Оба unit-файла (deploy-server, control-api) подключают этот файл через EnvironmentFile.

# --- Общие: метаданные и связь control-api → deploy-server ---
#
# Нативная установка (install.sh): метаданные в SQLite.
DEPLOY_SQLITE_URL=sqlite:///var/lib/pirate/deploy/deploy.db
#
# Docker / отдельный Postgres для метаданных (не смешивайте с DEPLOY_SQLITE_URL на одном хосте без необходимости):
# DATABASE_URL=postgresql://deploy:CHANGEME@127.0.0.1:5432/deploy
#
# Опционально: отдельный PostgreSQL только для встроенного explorer в UI (когда метаданные в SQLite).
# install.sh с pirate_INSTALL_POSTGRESQL=1 добавит строку автоматически; либо вручную:
# POSTGRES_EXPLORER_URL=postgresql://user:pass@127.0.0.1:5432/otherdb

DEPLOY_ROOT=/var/lib/pirate/deploy
GRPC_ENDPOINT=http://[::1]:50051
RUST_LOG=info

# --- deploy-server (gRPC) ---
#
# Публичный URL gRPC для клиентов (pairing, pirate-client, bootstrap JSON). Должен совпадать с тем,
# как машины в LAN/WAN реально подключаются к deploy-server (имя или IP, порт, http/https).
# Примеры:
#   LAN:    DEPLOY_GRPC_PUBLIC_URL=http://192.168.1.10:50051
#   Интернет (TLS на nginx/stream): DEPLOY_GRPC_PUBLIC_URL=https://grpc.example.com:443
# install.sh задаёт DEPLOY_GRPC_PUBLIC_URL по домену или IP; при смене сети поправьте вручную.
# DEPLOY_GRPC_PUBLIC_URL=http://example.com:50051
#
# Тот же URL читает control-api для GET /api/v1/bootstrap-hints и /api/v1/public/pirate-bootstrap/:token
# (переменная также: CONTROL_API_GRPC_PUBLIC_URL — дублирует смысл для одного .env).
#
# Базовый URL HTTP control-api для десктопа / GetStatus. Должен совпадать с тем, что реально открыт
# с машины клиента (браузер/curl/desktop), иначе логин по JWT даст client error (Connect).
#
# С nginx (рекомендуется): HTTP(S) вход на :80/:443, в конфиге proxy_pass на 127.0.0.1:8080 — в PUBLIC URL
# без порта (или :443 для https://).
#   LAN:    DEPLOY_CONTROL_API_PUBLIC_URL=http://192.168.1.10
#   WAN:    DEPLOY_CONTROL_API_PUBLIC_URL=https://dashboard.example.com
#
# Без nginx: control-api должен слушать на всех интерфейсах — см. CONTROL_API_BIND ниже; firewall открыть
# 8080/tcp; PUBLIC URL с портом, по которому клиент достучится:
#   LAN:    DEPLOY_CONTROL_API_PUBLIC_URL=http://192.168.1.10:8080
#
# Если не задано, deploy-server подставляет «прямой» http://<хост>:8080 из DEPLOY_GRPC_PUBLIC_URL — с LAN
# это часто недоступно при CONTROL_API_BIND=127.0.0.1 (только loopback), пока снаружи не nginx и не
# открыт прямой bind на 0.0.0.0:8080.
# DEPLOY_CONTROL_API_PUBLIC_URL=http://192.168.1.10
# DEPLOY_CONTROL_API_DIRECT_URL=http://127.0.0.1:8080
#
# OTA бандла стека (UploadServerStack). Допустимо: 1 / true / yes (выкл.: 0 / false).
# DEPLOY_ALLOW_SERVER_STACK_UPDATE=1
# Максимальный размер OTA tarball (байты); по умолчанию 536870912 (512 MiB).
# DEPLOY_MAX_SERVER_STACK_BYTES=536870912
#
# Каталог ключей вместо <DEPLOY_ROOT>/.keys (редко нужно).
# DEPLOY_KEYS_DIR=/var/lib/pirate/deploy/.keys
#
# Только dev/test: отключает аутентификацию gRPC. В проде не включать.
# DEPLOY_GRPC_ALLOW_UNAUTHENTICATED=1
#
# Путь к лог-файлу приложения: последняя строка в gRPC GetHostStats как log_tail (не путать с CONTROL_API_LOG_TAIL_PATH).
# DEPLOY_HOST_STATS_LOG_TAIL=/var/log/myapp.log
#
# Ограничение хостов для gRPC ProxyTunnel: список через запятую (суффиксы .host тоже допускаются).
# Не задано, пусто или * — без ограничения по имени хоста. Иначе только перечисленные хосты.
# DEPLOY_PROXY_ALLOWLIST=example.com,api.example.org
#
# Максимальный размер одного артефакта проекта (байты), gRPC Upload и HTTP multipart в control-api.
# Совпадает с флагом deploy-server --max-upload-bytes (переменная читается через clap при старте).
# ВАЖНО: одно и то же значение должно действовать и для deploy-server, и для control-api (обычно один
# файл `/etc/pirate-deploy.env` для обоих systemd-юнитов). Иначе клиент упрётся в разный лимит по слоям.
# control-api применяет min(DEPLOY_MAX_UPLOAD_BYTES, deploy-server GetStatus.max_upload_bytes) для HTTP deploy.
# Пример: 268435456 = 256 MiB.
# Если в ошибке фигурирует ровно 10485760 — на хосте выставлено 10 MiB; увеличьте и перезапустите оба сервиса.
# DEPLOY_MAX_UPLOAD_BYTES=268435456
#
# QUIC data-plane (UDP) для proxy: по умолчанию включён. Отключение — без пересборки, если нужен только gRPC/TCP:
#   DEPLOY_QUIC_DATAPLANE=0   (или false / off)
# DEPLOY_QUIC_DATAPLANE=0

# --- control-api (HTTP) ---
#
CONTROL_API_PORT=8080
# install.sh задаёт 127.0.0.1 (только localhost) — с другой машины в LAN порт 8080 не откроется даже при
# открытом firewall; нужен nginx на :80/:443 или прямой bind (осторожно в WAN без TLS):
#   CONTROL_API_BIND=0.0.0.0
# Для IPv6-all можно использовать :: (см. документацию окружения). UFW: при nginx открыть 80/tcp, 443/tcp
# (если TLS) и порт gRPC (часто 50051/tcp); без nginx — ещё 8080/tcp с нужных сетей.
CONTROL_API_BIND=127.0.0.1
#
# Редактирование /etc/pirate-deploy.env с дашборда (desktop «Окружение» → сервер): путь к файлу и к helper
# (install.sh кладёт pirate-write-deploy-env.sh и sudoers). Обычно менять не нужно.
# CONTROL_API_HOST_DEPLOY_ENV_PATH=/etc/pirate-deploy.env
# CONTROL_API_WRITE_DEPLOY_ENV_SCRIPT=/usr/local/lib/pirate/pirate-write-deploy-env.sh
#
# JWT: время жизни токена (секунды), по умолчанию 28800.
# CONTROL_API_JWT_TTL_SECS=28800
#
# HTTP POST multipart `/api/v1/projects/:id/deploy-artifact` → gRPC: размер чанка (байты).
# CONTROL_API_DEPLOY_CHUNK_BYTES=262144
#
# Resumable upload session API: размер клиентского чанка (байты), который принимает session API.
# Resumable upload session API: время жизни upload-сессии в секундах до автоматического истечения.
# CONTROL_API_DEPLOY_SESSION_CHUNK_BYTES=1048576
# CONTROL_API_DEPLOY_SESSION_TTL_SECS=3600
#
# После bootstrap-grpc-key install.sh дописывает путь к ключу подписи gRPC.
# GRPC_SIGNING_KEY_PATH=/var/lib/pirate/deploy/.keys/control_api_ed25519.json
#
# Статический Bearer в дополнение к JWT (автоматизация / машинные клиенты).
# CONTROL_API_BEARER_TOKEN=
#
# CORS: для dev можно CONTROL_API_CORS_ALLOW_ANY=1; иначе список origin через запятую.
# CONTROL_API_CORS_ALLOW_ANY=1
# CONTROL_API_CORS_ORIGINS=http://localhost:5173,https://dashboard.example.com
#
# Публичный базовый URL дашборда (https://домен) — для ссылок subscription и pirate-bootstrap в Inbounds.
# Должен совпадать с тем, что открывают в браузере / desktop (за nginx, обычно тот же host что и UI).
# Без этого subscription_url / pirate_bootstrap_url в ответе create proxy session не собираются.
# DEPLOY_SUBSCRIPTION_PUBLIC_HOST=https://dashboard.example.com
# DEPLOY_SUBSCRIPTION_TLS_SNI=   # опционально SNI для экспорта Xray (ingress)
# Альтернативное имя: CONTROL_API_SUBSCRIPTION_PUBLIC_HOST
#
# Для публичного JSON pirate-bootstrap (gRPC URL + метаданные сессии) задайте также DEPLOY_GRPC_PUBLIC_URL выше.
#
# CONTROL_API_HOST_STATS_SERIES и CONTROL_API_HOST_STATS_STREAM — сбор статистики хостов в дашборде:
#   CONTROL_API_HOST_STATS_SERIES=1  # исторические данные (графики за период)
#   CONTROL_API_HOST_STATS_STREAM=1  # потоковая телеметрия (SSE/WebSocket в UI)
#
# Интерактивная оболочка на хосте через WebSocket (desktop / JWT): GET /api/v1/host-terminal/ws — только Unix, выключено по умолчанию.
# Работает от имени пользователя ОС, под которым запущен control-api; не включать на публичных WAN без TLS и строгой политики.
#   CONTROL_API_HOST_TERMINAL=1
#   CONTROL_API_HOST_TERMINAL_SHELL=/bin/bash
#   CONTROL_API_HOST_TERMINAL_SESSION_SECS=3600
#
# Политика трансляции экрана (install.sh): согласие администратора на использование display stream с этого хоста.
# Пишется install.sh; см. также /var/lib/pirate/host-gui-install.json и `pirate gui-check`.
# PIRATE_DISPLAY_STREAM_CONSENT=0

# Корень для кредов БД и SMB-артефактов (по умолчанию /var/lib/pirate/db-mounts).
# PIRATE_DATA_MOUNTS_ROOT=/var/lib/pirate/db-mounts
#
# Хвост этого файла в HTTP GET /api/v1/host-stats как log_tail (не путать с DEPLOY_HOST_STATS_LOG_TAIL на deploy-server).
# CONTROL_API_LOG_TAIL_PATH=/var/log/control-api.log
#
# Опционально: правка конфига nginx через API (для нативного install.sh обычно не нужно).
# NGINX_CONFIG_PATH=/etc/nginx/nginx.conf
# NGINX_TEST_FULL_CONFIG=0
# NGINX_ADMIN_TOKEN=
#
# Автоуправление nginx из desktop (вкладка nginx): helper-скрипты и путь vhost.
# Обычно не менять: install.sh/OTA кладут скрипты в /usr/local/lib/pirate.
# CONTROL_API_NGINX_SITE_PATH=/etc/nginx/sites-available/pirate
# CONTROL_API_NGINX_ENSURE_SCRIPT=/usr/local/lib/pirate/pirate-ensure-nginx.sh
# CONTROL_API_NGINX_APPLY_SITE_SCRIPT=/usr/local/lib/pirate/pirate-nginx-apply-site.sh

# --- WAN security (ACME + firewall minimal-open policy) ---
#
# Рекомендуется при [network].mode=wan:
#   1) включить https в pirate.toml ([network.tls].https=true)
#   2) задать домен и email
#   3) применить helper-скрипты:
#      sudo /usr/local/lib/pirate/pirate-ensure-https.sh "$PIRATE_WAN_DOMAIN" "$PIRATE_WAN_ACME_EMAIL"
#      sudo /usr/local/lib/pirate/pirate-firewall-apply.sh wan 50051
#
# PIRATE_WAN_DOMAIN=example.com
# PIRATE_WAN_ACME_EMAIL=ops@example.com
# PIRATE_WAN_FIREWALL_MANAGED=1

# --- Веб-дашборд (JWT + первый пользователь) ---
#
# С --ui install.sh добавляет строки ниже; без --ui JWT не задаётся — см. README.
# CONTROL_UI_ADMIN_USERNAME=admin
# CONTROL_UI_ADMIN_PASSWORD=CHANGEME
# CONTROL_API_JWT_SECRET=CHANGEME
#
# Принудительно перезаписать пароль сида при следующем старте deploy-server (после смены CONTROL_UI_ADMIN_PASSWORD).
# CONTROL_UI_ADMIN_PASSWORD_RESET=1
#
# Только для CLI: deploy-server dashboard-add-user — пароль из env, если не передан --password.
# DEPLOY_DASHBOARD_PASSWORD=

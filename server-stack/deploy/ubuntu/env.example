# Скопируйте в /etc/pirate-deploy.env и поправьте пароль при необходимости.
# Формат URL: postgresql://USER:PASSWORD@HOST:PORT/DBNAME

DATABASE_URL=postgresql://deploy:CHANGEME@127.0.0.1:5432/deploy

# Каталог артефактов (releases/, current) — совпадает с путём в systemd (install.sh)
DEPLOY_ROOT=/var/lib/pirate/deploy

# gRPC deploy-server (loopback; для control-api)
GRPC_ENDPOINT=http://[::1]:50051

# Публичный URL gRPC для pairing-бандла в логах deploy-server и для клиентов вне хоста.
# Обычно тот же хост, что и веб-интерфейс, порт 50051; порт должен быть открыт снаружи.
# Задаётся автоматически при установке с pirate_DOMAIN / --domain (см. install.sh).
# DEPLOY_GRPC_PUBLIC_URL=http://deploy.example.com:50051

# HTTP control-api (внутренний порт за nginx)
CONTROL_API_PORT=8080

# Ed25519 JSON identity для подписанных gRPC-вызовов control-api → deploy-server (GetStatus, rollback, …).
# Создаётся install.sh через `control-api bootstrap-grpc-key` или вручную.
# GRPC_SIGNING_KEY_PATH=/var/lib/pirate/deploy/.keys/control_api_ed25519.json

# Только для dev/теста: отключить проверку метаданных на deploy-server (не использовать в продакшене).
# DEPLOY_GRPC_ALLOW_UNAUTHENTICATED=1

RUST_LOG=info

# Дашборд: логин/пароль (seed в БД при старте deploy-server; пароль не перезаписывается без CONTROL_UI_ADMIN_PASSWORD_RESET=1)
# CONTROL_UI_ADMIN_USERNAME=admin
# CONTROL_UI_ADMIN_PASSWORD=
# CONTROL_UI_ADMIN_PASSWORD_RESET=
# Добавить пользователя вручную (от пользователя deploy, см. deploy/ubuntu/Makefile):
# deploy-server --root /var/lib/pirate/deploy dashboard-add-user --username NAME --password PASS
# или пароль из окружения: DEPLOY_DASHBOARD_PASSWORD=… dashboard-add-user --username NAME
# Подпись JWT для control-api (обязательно, если входите через веб-форму)
# CONTROL_API_JWT_SECRET=

# Опционально: правка конфига nginx из UI (путь к site-файлу)
# NGINX_CONFIG_PATH=/etc/nginx/sites-available/pirate
# NGINX_TEST_FULL_CONFIG=false
# NGINX_ADMIN_TOKEN=
